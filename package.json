{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --no-cache server.ts",
    "build": "node scripts/build-plugins.mjs && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint . --ext .ts,.tsx --ignore-pattern dist --ignore-pattern node_modules",
    "format": "prettier --write .",
    "test": "vitest run",
    "migrate-passwords": "node -e \"console.log('Run this script to batch-upgrade password hashes. See server/utils/migrate-passwords.ts')\"",
    "db:backup": "node -e \"const db = require('./packages/core/db/index.js'); db.db.exec('VACUUM INTO \\'backup_'+Date.now()+'.db\\'');\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/reveal.js": "^5.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "konva": "^10.3.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pptx-preview": "^0.0.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-konva": "^19.2.4",
    "react-konva-utils": "^2.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "reveal.js": "^6.0.1",
    "semver": "^7.8.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "xss": "^1.0.15",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pino": "^7.0.4",
    "@types/uuid": "^10.0.0",
    "@types/xlsx": "^0.0.35",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
